{
  "ConnectionStrings": {
    "SQLServer": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "LogSettings": {
    "LogPath": "Logs",
    "LogFileName": "user-sync-{Date}.log",
    "RetainDays": 30,
    "EnableDatabaseLog": true
  },
  "SyncSettings": {
    "CheckIntervalSeconds": 3600,
    "EnableAutoSync": true,
    "ManufactureGdname4DefaultFactory": "",
    "ManufactureGdname4Factories": [
      { "Gdname4": "广东创世纪制造部", "Factory": "1030,1010" },
      { "Gdname4": "湖州制造总部", "Factory": "1060" },
      { "Gdname4": "沙田制造部", "Factory": "1030" },
      { "Gdname4": "宜宾制造基地", "Factory": "1040" },
      { "Gdname4": "越南制造基地", "Factory": "2310" }
    ],
    "SyncTasks": {
      "SyncNewUsersFromVps": true,
      "GenerateUserLogOn": true,
      "UpdateEmptyPasswords": true,
      "SyncBasePeopleFromVps": true,
      "SyncBasePeopleSysUser": true,
      "SyncSysUserEnabledMark": true,
      "SyncBasePeopleJobStatus": true
    }
  }
}
